# SPA routing: serve index.html for any path that isn't a real file/dir,
# so deep links like /watch/123 work on refresh (OpenLiteSpeed/Apache).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
